# ──────────────────────────────────────────────────────
# DevNexa Global — Environment Variables Template
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────
APP_NAME=DevNexa Global
APP_ENV=production

# ── MySQL 8 Database ───────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=devnexadb
MYSQL_USER=devnexa_user
MYSQL_PASSWORD=change_me_db_password

# ── Redis Cache ────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── JWT Security ───────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=change_me_generate_a_secure_base64_secret_key_here

# ── Google Gemini AI ───────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── Stripe Payments ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret

# ── Email SMTP (Gmail) ─────────────────────────────────
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password_16_chars

# ── File Storage ───────────────────────────────────────
FILE_STORAGE_PATH=/app/uploads
FILE_MAX_SIZE_MB=50

# ── Domain & SSL ───────────────────────────────────────
DOMAIN=devnexa.global
SSL_EMAIL=admin@devnexa.global

# ── Google Analytics ───────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Optional: PostgreSQL (use --profile postgres) ──────
POSTGRES_DB=devnexadb
POSTGRES_USER=devnexa_user
POSTGRES_PASSWORD=change_me_postgres_password
